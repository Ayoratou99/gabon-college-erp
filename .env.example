APP_NAME="CUK Concours"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Libreville
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ---- Logging
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=debug

# ---- Database (PostgreSQL — only thing in Docker)
# Postgres runs in `docker compose up -d`; the PHP app + nginx-equivalent
# (Apache via WAMP) live on the host directly. Hostname is `127.0.0.1`
# because the container publishes 5432 on the host loopback.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cuk
DB_USERNAME=cuk
DB_PASSWORD=cuk_local_password

# ---- Cache / Queue / Session — file-backed (no Redis required)
BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_PREFIX=cuk
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false   # set true behind HTTPS
SESSION_SAME_SITE=lax

# ---- Mail
# In local dev we just log every outgoing message to storage/logs/laravel.log
# (open the file to inspect it).  For staging/prod, switch MAIL_MAILER to smtp
# and fill the credentials below.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@cuk.ga
MAIL_FROM_NAME="${APP_NAME}"

# ---- File storage
FILESYSTEM_DISK=local
LEGACY_DOCUMENTS_PATH=./legacy/documentcupk
LEGACY_PROFILE_IMAGES_PATH=./legacy/imageprofilecupk

# ---- Auth & Security
AUTH_GUARD=web
AUTH_MODEL=Modules\UserManagement\Models\User
PASSWORD_LEGACY_REHASH=true    # accept old SHA1 once, rehash to bcrypt

# Throttling tiers (login.attempts.<tier>)
LOGIN_THROTTLE_FAST_MAX=3
LOGIN_THROTTLE_FAST_DECAY=900   # 15 min
LOGIN_THROTTLE_SLOW_MAX=5
LOGIN_THROTTLE_SLOW_DECAY=86400 # 24 h

# ---- 2FA
GOOGLE2FA_ENABLED=true
GOOGLE2FA_ISSUER="Concours CUK"
GOOGLE2FA_WINDOW=1
GOOGLE2FA_LIFETIME=0
GOOGLE2FA_KEEP_ALIVE=true
GOOGLE2FA_FORCE_FOR_ROLES=super-admin,dg,de,chef-centre

# ---- reCAPTCHA v3
# Leave empty in local dev — reCAPTCHA is auto-disabled in that case.
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# ---- eBilling (paiement frais de concours)
# Operational secrets — never seeded into the database. Rotate by editing
# this file and restarting Apache (no docker rebuild needed).
EBILLING_BASE_URL=https://lab.billing-easy.net
EBILLING_PORTAL_URL=https://lab.billing-easy.net
EBILLING_USERNAME=
EBILLING_SHARED_KEY=
EBILLING_HTTP_TIMEOUT=8
# AES-256-GCM key used to encrypt the external_reference we send to eBilling.
# eBilling does not sign the callback body — we verify authenticity by
# round-tripping the reference through this key. Generate a fresh one with:
#   php -r "echo 'base64:' . base64_encode(random_bytes(32));"
EBILLING_REFERENCE_KEY=
# Single source of truth for the default fee, picked up if the active session
# has no per-session override and the settings table can't be reached.
CONCOURS_DEFAULT_FEE=10300

# Prod test candidate (QA backdoor). Empty = disabled. When set, registering
# with this exact email on an open session creates/updates ONE hidden test
# candidate (matricule CUK-{year}-00000), charged CONCOURS_TEST_FEE instead of
# the real fee, visible/manageable by super-admin only.
CONCOURS_TEST_EMAIL=
CONCOURS_TEST_FEE=100

# ---- Permissions cache (file store — change to redis if you re-add Redis)
PERMISSIONS_CACHE_TTL=3600
PERMISSIONS_CACHE_STORE=file
SETTINGS_CACHE_STORE=file

# ---- Modules
MODULES_CACHE_ENABLED=true
