APP_NAME="CUK Concours"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Libreville
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ---- Logging
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=debug

# ---- Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cuk
DB_USERNAME=cuk
DB_PASSWORD=cuk_local_password

# ---- Cache / Queue / Session — all on Redis
BROADCAST_CONNECTION=log
CACHE_STORE=redis
CACHE_PREFIX=cuk
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false  # set true behind HTTPS
SESSION_SAME_SITE=lax

# ---- Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ---- Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@cuk.ga
MAIL_FROM_NAME="${APP_NAME}"

# ---- File storage (transition: legacy folders mounted read-only)
FILESYSTEM_DISK=local
LEGACY_DOCUMENTS_PATH=/legacy/documentcupk
LEGACY_PROFILE_IMAGES_PATH=/legacy/imageprofilecupk

# ---- Auth & Security
AUTH_GUARD=web
AUTH_MODEL=Modules\UserManagement\Models\User
PASSWORD_LEGACY_REHASH=true    # accept old SHA1 once, rehash to bcrypt

# Throttling tiers (login.attempts.<tier>)
LOGIN_THROTTLE_FAST_MAX=3
LOGIN_THROTTLE_FAST_DECAY=900   # 15 min
LOGIN_THROTTLE_SLOW_MAX=5
LOGIN_THROTTLE_SLOW_DECAY=86400 # 24 h

# ---- 2FA
GOOGLE2FA_ENABLED=true
GOOGLE2FA_ISSUER="Concours CUK"
GOOGLE2FA_WINDOW=1
GOOGLE2FA_LIFETIME=0
GOOGLE2FA_KEEP_ALIVE=true
GOOGLE2FA_FORCE_FOR_ROLES=super-admin,dg,de,chef-centre

# ---- reCAPTCHA v3
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# ---- eBilling (paiement frais de concours)
EBILLING_BASE_URL=https://lab.billing-easy.net
EBILLING_USERNAME=CUK
EBILLING_SHARED_KEY=
EBILLING_HMAC_SECRET=
EBILLING_PAYER_EMAIL=
EBILLING_PAYER_MSISDN=
EBILLING_PAYER_NAME=

# ---- Permissions cache
PERMISSIONS_CACHE_TTL=3600
PERMISSIONS_CACHE_STORE=redis

# ---- Modules
MODULES_CACHE_ENABLED=true

# ---- Horizon / Pulse / Telescope
HORIZON_PREFIX=cuk-horizon:
PULSE_ENABLED=true
