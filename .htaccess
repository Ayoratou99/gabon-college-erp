# Project-root .htaccess — used when the web server's document root is the
# APP ROOT (not public/). On LWS, a subdomain's docroot is the directory named
# after it (e.g. cuk.univ-masuku.org/), which IS this folder — so requests land
# here and must be forwarded into Laravel's public/ front controller.
#
#   cuk.univ-masuku.org/            -> public/index.php  (home)
#   cuk.univ-masuku.org/inscription -> public/index.php  (route)
#   cuk.univ-masuku.org/build/x.css -> public/build/x.css (real asset, served)
#
# In .env (at a domain root):
#   APP_URL=https://cuk.univ-masuku.org
#   ASSET_URL=https://cuk.univ-masuku.org

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) If the URL maps to a real file under public/ (compiled assets, images,
    #    favicon, robots…), serve it from there.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^ public%{REQUEST_URI} [L]

    # 2) Everything else — including the bare domain "/" and every route — goes
    #    straight to the front controller. Routing to index.php directly avoids
    #    the "directory without trailing slash" 404 you get when rewriting to
    #    the public/ directory and relying on mod_dir.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^ public/index.php [L]
</IfModule>

# Defence in depth: never serve sensitive root files over HTTP (the front
# controller never references them; this guards against a misconfiguration).
<FilesMatch "\.(env|json|lock|md|sh|sql|yml|yaml|log|dump|sqlite)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule (^|/)\.(git|github|env) - [F]
</IfModule>
