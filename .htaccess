# Project-root .htaccess — document root is the APP ROOT (not public/).
# Forwards every request into Laravel's public/ front controller WITHOUT
# exposing /public/ in the URL and WITHOUT a rewrite loop.
#
# Proven shared-hosting pattern (cPanel/LWS/OVH). The LEADING SLASH on the
# targets ( /public/$1 , /public/index.php ) is essential: it makes the rewrite
# resolve under /public/, which is then handled by public/.htaccess — a
# DIFFERENT per-directory context — so THIS file never re-processes the request.
# A relative target ("public/index.php") re-enters this .htaccess on every
# internal sub-request and loops → 500 Internal Server Error.
#
# .env (domain root):
#   APP_URL=https://cuk.univ-masuku.org
#   ASSET_URL=https://cuk.univ-masuku.org

<FilesMatch "\.(env|sql|dump|sqlite|log)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Serve real files that live under public/ (compiled assets, images,
    #    favicon…) as if they were at the root.
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule (.+) /public/$1 [L]

    # 2) Everything else — the bare domain "/" and every route — to the front
    #    controller (absolute path → /public/ context → no loop).
    RewriteRule ^ /public/index.php [L]
</IfModule>
