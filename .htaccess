# Project-root .htaccess — used when the web server's document root is the
# APP ROOT (not public/), e.g. shared hosting / an LWS subdomain whose docroot
# is this folder. Forwards every request into Laravel's public/ front
# controller WITHOUT exposing /public/ and WITHOUT a rewrite loop.
#
# NOTE: this file is ONLY read when the docroot is the app root. Local dev
# (`php artisan serve`, or a vhost pointing straight at public/) never reads it.
# It carries no host-specific paths — assets are matched by prefix, not by a
# filesystem probe — so the same file works on LWS, local Apache, and any host.
#
# The LEADING SLASH on the targets ( /public/$1 , /public/index.php ) is what
# prevents the 500 loop: the rewrite resolves under /public/, handled by
# public/.htaccess (a different per-directory context), so THIS file never
# re-processes the request. A relative target loops → 500.
#
# .env (domain root):
#   APP_URL=https://cuk.univ-masuku.org
#   ASSET_URL=https://cuk.univ-masuku.org

<FilesMatch "\.(env|sql|dump|sqlite|log)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Static assets that physically live under public/ (compiled Vite
    #    bundles, images, legacy photos, the storage symlink, favicon, robots)
    #    → serve them from /public/ by PREFIX, with NO filesystem -f test.
    #
    #    Why no -f test: on LWS shared hosting the site runs under CageFS, so a
    #    `RewriteCond <abs-path>%{REQUEST_URI} -f` check silently fails — the
    #    real chroot path the rewrite engine sees differs from the SSH-visible
    #    /home/htdocs/… path, and %{DOCUMENT_ROOT} isn't the subdomain folder
    #    either. The -f approach 404'd every asset in prod. Matching on the
    #    known top-level prefixes instead needs no path knowledge at all.
    #
    #    The /public/ target lands in public/.htaccess (a SEPARATE per-directory
    #    context) whose native %{REQUEST_FILENAME} -f test — computed by Apache,
    #    not hand-built — serves the real file. So THIS file never re-processes
    #    the request: no rewrite loop. A 404 there (missing file) is correct.
    RewriteRule ^(build|img|legacy|storage)(/.*)?$ /public/$1$2 [L]
    RewriteRule ^(favicon\.ico|robots\.txt)$ /public/$1 [L]

    # 2) Everything else — the bare domain "/" and every route — to the front
    #    controller (absolute path → /public/ context → no loop).
    RewriteRule ^ /public/index.php [L]
</IfModule>
