# =============================================================================
#  PRODUCTION .env TEMPLATE  (shared hosting, Laravel in a subfolder)
#  -------------------------------------------------------------------
#  On the server:  cp .env.production.example .env   then fill the blanks.
#  NEVER commit the real .env (it is git-ignored).
# =============================================================================

APP_NAME="CUK Concours"
APP_ENV=production
# ⚠️  KEEP THIS KEY IDENTICAL to the machine that produced the DB dump, otherwise
#     encrypted columns (2FA secrets, encrypted settings) will NOT decrypt.
APP_KEY=base64:BIB0reDtbEy7x3JdRmIc92EifYJfMxWH8SidROa9COs=
APP_DEBUG=false
APP_TIMEZONE=Africa/Libreville
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Public base URL — INCLUDE the subfolder. Both of these must point at it so
# routes + asset() (Vite build) resolve correctly under /<subfolder>/.
APP_URL=https://VOTRE-DOMAINE/SOUS-DOSSIER
ASSET_URL=https://VOTRE-DOMAINE/SOUS-DOSSIER

# ---- Logging (single file; shared hosting has no syslog/daily rotation cron)
LOG_CHANNEL=single
LOG_STACK=single
LOG_LEVEL=error

# ---- Database (PostgreSQL prod — credentials from your hosting panel)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=VOTRE_BASE
DB_USERNAME=VOTRE_USER
DB_PASSWORD=VOTRE_MOT_DE_PASSE

# ---- Cache / Queue / Session — file-backed (no Redis on shared hosting)
BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_PREFIX=cuk
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# HTTPS in prod → secure cookies + SameSite
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ---- Mail (fill with your host's SMTP; "log" would silently drop mails)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@VOTRE-DOMAINE
MAIL_FROM_NAME="${APP_NAME}"

# ---- File storage
FILESYSTEM_DISK=local
# Legacy doc + photo folders. On shared hosting, drop them somewhere OUTSIDE the
# web root if you can; otherwise inside storage/app/private/legacy/ (NOT public).
LEGACY_DOCUMENTS_PATH=/home/VOTRE_COMPTE/legacy/documentcupk
LEGACY_PROFILE_IMAGES_PATH=/home/VOTRE_COMPTE/legacy/imageprofilecupk

# ---- Auth & Security
AUTH_GUARD=web
AUTH_MODEL=Modules\UserManagement\Models\User
PASSWORD_LEGACY_REHASH=true

LOGIN_THROTTLE_FAST_MAX=3
LOGIN_THROTTLE_FAST_DECAY=900
LOGIN_THROTTLE_SLOW_MAX=5
LOGIN_THROTTLE_SLOW_DECAY=86400

# ---- 2FA
GOOGLE2FA_ENABLED=true
GOOGLE2FA_ISSUER="Concours CUK"
GOOGLE2FA_WINDOW=1
GOOGLE2FA_LIFETIME=0
GOOGLE2FA_KEEP_ALIVE=true
GOOGLE2FA_FORCE_FOR_ROLES=super-admin,dg,de,chef-centre

# ---- reCAPTCHA v3 (fill to enable; empty = auto-disabled)
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# ---- eBilling (PRODUCTION endpoint + real credentials)
EBILLING_BASE_URL=https://www.billing-easy.com
EBILLING_PORTAL_URL=https://www.billing-easy.com
EBILLING_USERNAME=
EBILLING_SHARED_KEY=
EBILLING_HTTP_TIMEOUT=8
# AES-256-GCM key for the encrypted external_reference. KEEP IDENTICAL to the
# value used when the existing payments were created, or callbacks won't verify.
EBILLING_REFERENCE_KEY=base64:Y4ZQXVhGDAWxtt0R/O12v6zSTiAhOSOj2RNSXsidl24=

# ---- Prod test candidate (QA backdoor). Empty = DISABLED (recommended once
# real testing is done). When set, registering with this exact email creates a
# single hidden test candidate (matricule CUK-{year}-00000), charged
# CONCOURS_TEST_FEE, visible/manageable by super-admin only.
CONCOURS_TEST_EMAIL=test@gmail.com
CONCOURS_TEST_FEE=100

# ---- Permissions / settings cache (file store)
PERMISSIONS_CACHE_TTL=3600
PERMISSIONS_CACHE_STORE=file
SETTINGS_CACHE_STORE=file

# ---- Modules
MODULES_CACHE_ENABLED=true
