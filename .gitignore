/node_modules
# NOTE: /public/build is intentionally COMMITTED for shared-hosting deploys —
# the host has no Node, so `npm run build` can't run there. Rebuild locally
# (`npm run build`) before each push so the latest compiled assets ship via git.
# /public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor

# IDEs
/.idea
/.vscode
/.fleet
/.zed

# Local env
.env
.env.backup
.env.production
.env.*.local

# Docker
.docker/postgres/data
.docker/redis/data

# Generated
/.phpunit.cache
/.phpunit.result.cache
/auth.json
/npm-debug.log
/yarn-error.log

# Laravel
/bootstrap/ssr
/storage/app/private
# Keep storage/app/public ignored EXCEPT the historical-results folder, which
# holds the legacy procès-verbal PDF served on /resultats. Committing it means
# prod gets the file via `git pull` (the dump doesn't carry storage files).
/storage/app/public/*
!/storage/app/public/historical-results
/storage/framework/cache/data
/storage/framework/sessions
/storage/framework/testing
/storage/framework/views
/storage/logs/*.log

# nWidart modules cache
/bootstrap/cache/modules.php
/bootstrap/cache/packages.php
/bootstrap/cache/services.php
/bootstrap/cache/config.php
/bootstrap/cache/routes-*.php
/bootstrap/cache/events.php

# OS junk
.DS_Store
Thumbs.db
